// LifeOS AI — Prisma schema.
// Lives at the repo root per docs/07-folder-structure.md so it's shared, not owned by one app.
// Milestone 1 intentionally defines only the datasource/generator — no domain models yet.
// Models are added incrementally, one feature milestone at a time (see docs/09-roadmap.md),
// starting with the Auth milestone's User/RefreshToken/UserSettings tables from
// docs/06-database-design.md.

generator client {
  provider = "prisma-client-js"
  output   = "../apps/backend/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
