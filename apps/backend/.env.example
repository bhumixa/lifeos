# Copy this file to .env and adjust as needed for local development.
# See docker-compose.yml at the repo root for the matching local Postgres/Redis credentials.

NODE_ENV=development
PORT=3000

# Matches docker-compose.yml's postgres service.
DATABASE_URL="postgresql://lifeos:lifeos@localhost:5432/lifeos?schema=public"

# Angular dev server default port — used for the CORS allow-list.
FRONTEND_URL="http://localhost:4200"

# Auth (Milestone 2). Generate with `openssl rand -base64 48` — must be at least 32 chars.
JWT_ACCESS_SECRET="RENFtZmzH26i7+w3Ox1XrwD0tlkEcky/6wf5hQjtKsMSeH9mhP25VH61oCOwQdni"
JWT_ACCESS_EXPIRES_IN="15m"
# How long a rotated refresh token (delivered via httpOnly cookie) stays valid.
JWT_REFRESH_TOKEN_TTL_DAYS=30
BCRYPT_SALT_ROUNDS=12
